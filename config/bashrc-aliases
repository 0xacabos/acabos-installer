# ACABOS bashrc aliases and integrations

alias start-sway='start-desktop'
alias nvidia='nvidia-smi'
alias nvtop='nvtop || nvidia-smi'
alias gpustat='watch -n 1 nvidia-smi'
alias ll='eza -alF'
alias la='eza -a'
alias l='eza -F'
alias cat='bat --paging=never'
alias grep='rg'
alias fd='fdfind'
alias find='fdfind'
alias docker='podman'
alias docker-compose='podman-compose'
alias d='podman'
alias dc='podman-compose'
alias svim='sudo vim'
alias sconfig='vim ~/.config/sway/config'
alias wconfig='vim ~/.config/waybar/config'
alias temp='sensors'
alias mem='free -h'
alias disk='df -h'
alias ports='ss -tulanp'
alias myip='curl -s ifconfig.me'
alias weather='curl -s wttr.in | head -20'

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init bash)"
fi
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init bash)"
fi
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook bash)"
fi
