# Example ACABOS mistral.rs profile
# Copy this file to /etc/acabos/inference/<profile>.env and customize it.

# Example text model on port 8012:
ACAB_MISTRAL_SERVE_ARGS="-p 8012 auto -m mistralai/Mistral-7B-Instruct-v0.2 --token-source env:HF_TOKEN"

# Optional Hugging Face token for gated/private models.
# HF_TOKEN=hf_xxx
