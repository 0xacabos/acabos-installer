# NVIDIA optimizations for Sway
set $env_nvidia __GLX_VENDOR_LIBRARY_NAME=nvidia
set $env_gbm GBM_BACKEND=nvidia-drm

exec --no-startup-id dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=sway

# NVIDIA-specific env vars applied to all child processes
exec_always --no-startup-id export __GLX_VENDOR_LIBRARY_NAME=nvidia
exec_always --no-startup-id export _JAVA_AWT_WM_NONREPARENTING=1
exec_always --no-startup-id export GBM_BACKEND=nvidia-drm
exec_always --no-startup-id export __GL_GSYNC_ALLOWED=1
exec_always --no-startup-id export __GL_VRR_ALLOWED=1
exec_always --no-startup-id export WLR_NO_HARDWARE_CURSORS=1
exec_always --no-startup-id export QT_QPA_PLATFORM=wayland
exec_always --no-startup-id export QT_WAYLAND_DISABLE_WINDOWDECORATION=1
exec_always --no-startup-id export GDK_BACKEND=wayland
exec_always --no-startup-id export SDL_VIDEODRIVER=wayland
exec_always --no-startup-id export CLUTTER_BACKEND=wayland
exec_always --no-startup-id export MOZ_ENABLE_WAYLAND=1
exec_always --no-startup-id export ELECTRON_OZONE_PLATFORM_HINT=wayland
exec_always --no-startup-id export CUDA_CACHE_DISABLE=0
